@echo off
echo =========================================
echo 正在執行專案建置 (npm run build)...
echo =========================================
call npm run build
if %errorlevel% neq 0 (
    echo [錯誤] 建置失敗，請檢查程式碼！
    pause
    exit /b
)

echo =========================================
echo 正在將檔案加入版本控制...
echo =========================================
git add .

echo =========================================
echo 正在提交變更...
echo =========================================
set /p msg="請輸入本次更新訊息: "
git commit -m "%msg%"

echo =========================================
echo 正在推送到 GitHub...
echo =========================================
:: 將 main 改為 master
git push origin master

echo =========================================
echo 上傳完成！
echo =========================================
pause